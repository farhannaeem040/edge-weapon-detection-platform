# Central platform configuration template (IP-04).
#
# Copy to `.env` and fill in real values, or simply run:
#
#     powershell -ExecutionPolicy Bypass -File deployment/start.ps1
#
# which creates `.env` for you with cryptographically generated local-development secrets and
# never overwrites an existing one.
#
# `.env` is git-ignored and must never be committed. This template contains PLACEHOLDERS ONLY.
#
# Note on scope: a local `.env` file is an appropriate secret store for this trusted-LAN prototype
# (ARCH-001 §9.1/§15.6, ADR-002). It is NOT a production secret store — see deployment/README.md.

# Host port for the single public origin (Angular SPA + /api reverse proxy).
# Change this if 8080 is already in use on your machine.
APP_PORT=8080

# Application database name created by the EF Core migration job.
SQL_DATABASE=WeaponDetection

# SQL Server `sa` password for the containerized database.
# Must satisfy SQL Server complexity rules: at least 8 characters, containing three of
# uppercase, lowercase, digits, and non-alphanumeric characters.
SQL_SERVER_PASSWORD=replace-with-generated-value

# JWT signing key for Admin session tokens.
# JwtOptionsValidator rejects anything shorter than 32 UTF-8 bytes at startup.
JWT_SIGNING_KEY=replace-with-generated-value

# Bootstrap Admin account, provisioned once at first Backend startup when no Admin exists.
# These are the credentials you sign in to the Dashboard with.
ADMIN_IDENTIFIER=admin
ADMIN_PASSWORD=replace-with-generated-value
