{
  "info": {
    "_postman_id": "5524b81e-9fd7-4891-8c29-weapon-detection",
    "name": "Weapon Detection Backend API",
    "description": "Postman collection for the local Weapon Detection backend. Import the matching `Weapon Detection Local` environment first, then run Login before protected requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "health"
              ]
            },
            "description": "Checks that the backend is alive. No login token required."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Health returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credentialIdentifier\": \"{{adminIdentifier}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Logs in as the admin user and saves the JWT into the `token` environment variable."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const token = body.data && body.data.token;",
                  "if (token) {",
                  "  pm.environment.set('token', token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "logout"
              ]
            },
            "description": "Revokes the current admin session token. Run Login again after this."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Logout returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Branches",
      "item": [
        {
          "name": "POST Create Branch",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Test Branch\",\n  \"address\": \"123 Test Street\",\n  \"contactDetails\": \"manager@example.com\",\n  \"cameras\": [\n    {\n      \"name\": \"Front Door\",\n      \"rtspUrl\": \"rtsp://camera.local/front\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/branches",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "branches"
              ]
            },
            "description": "Creates a branch, its first camera, reserved device, and activation key. Saves branchId, cameraId, and activationKey."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create branch returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const data = body.data;",
                  "if (data) {",
                  "  if (data.branchId) pm.environment.set('branchId', data.branchId);",
                  "  if (data.activationKey) pm.environment.set('activationKey', data.activationKey);",
                  "  if (data.cameras && data.cameras.length > 0) pm.environment.set('cameraId', data.cameras[0].cameraId);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET List Branches",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/branches",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "branches"
              ]
            },
            "description": "Returns all branches. Does not return plaintext activation keys."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('List branches returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Branch By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/branches/{{branchId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "branches",
                "{{branchId}}"
              ]
            },
            "description": "Returns one branch by branchId."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Get branch returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT Update Branch",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Updated Branch\",\n  \"address\": \"456 Updated Street\",\n  \"contactDetails\": \"updated-manager@example.com\",\n  \"cameras\": [\n    {\n      \"cameraId\": \"{{cameraId}}\",\n      \"name\": \"Front Door Updated\",\n      \"rtspUrl\": \"rtsp://camera.local/front-updated\"\n    },\n    {\n      \"cameraId\": null,\n      \"name\": \"Back Door\",\n      \"rtspUrl\": \"rtsp://camera.local/back\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/branches/{{branchId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "branches",
                "{{branchId}}"
              ]
            },
            "description": "Updates branch details. Existing cameraId updates a camera; null cameraId creates a new camera."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Update branch returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE Branch",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/branches/{{branchId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "branches",
                "{{branchId}}"
              ]
            },
            "description": "Deletes a branch and its dependent records. Run this last if you want to clean up the test branch."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Delete branch returns 200 or 404', function () {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Devices",
      "item": [
        {
          "name": "POST Regenerate Activation Key",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/devices/{{branchId}}/activation-key/regenerate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "devices",
                "{{branchId}}",
                "activation-key",
                "regenerate"
              ]
            },
            "description": "Regenerates the activation key for a branch's device. The route variable is the branchId."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Regenerate key returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const key = body.data && body.data.activationKey;",
                  "if (key) {",
                  "  pm.environment.set('activationKey', key);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Device By DeviceId",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/devices/{{deviceId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "devices",
                "{{deviceId}}"
              ]
            },
            "description": "Returns an activated device by its external DeviceId. Run Activate first so deviceId is known."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Get device returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Activation",
      "item": [
        {
          "name": "POST Activate Device",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"activationKey\": \"{{activationKey}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/activate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "activate"
              ]
            },
            "description": "Device/agent activation endpoint. Uses activationKey instead of admin JWT. Saves deviceId and sharedSecret."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Activate returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const data = body.data;",
                  "if (data) {",
                  "  if (data.deviceId) pm.environment.set('deviceId', data.deviceId);",
                  "  if (data.sharedSecret) pm.environment.set('sharedSecret', data.sharedSecret);",
                  "  if (data.branchId) pm.environment.set('branchId', data.branchId);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
